# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/

# Virtual / conda envs
.venv/
venv/
env/

# Dum-E runtime artifacts (regenerated; never committed)
runs/*
!runs/.gitkeep
# calibration/: track the reviewed calibration PROFILES; ignore transient captures
# (sweep traces, logs, .tmp, patches) which are large and regenerable.
calibration/*
!calibration/.gitkeep
!calibration/joints.json
!calibration/handeye.json

# Model weights (optional detectors; pulled on demand)
*.pt
*.onnx
weights/

# OS
.DS_Store

# VSCode C/C++ IntelliSense browse cache (large, regenerated)
.vscode/browse.vc.db*
